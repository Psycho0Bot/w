datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  USER
  ADVISOR
  ADMIN
}

enum AssetCategory {
  STOCK_IN
  STOCK_US
  MUTUAL_FUND
  CRYPTO
  GOLD
  FIXED_INCOME
  REAL_ESTATE
  CASH
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model User {
  id            String        @id @default(uuid())
  name          String?
  email         String        @unique
  passwordHash  String?
  role          Role          @default(USER)
  emailVerified DateTime?
  image         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  
  accounts      Account[]
  sessions      Session[]
  portfolios    Portfolio[]
  watchlists    Watchlist[]
  notifications Notification[]
  importJobs    ImportJob[]
  settings      Settings?
  auditLogs     AuditLog[]
  bookmarks     NewsBookmark[]
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id         String   @id @default(uuid())
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Settings {
  id             String  @id @default(uuid())
  userId         String  @unique
  currencyPref   String  @default("INR")
  themePref      String  @default("dark")
  googleSheetUrl String?
  portfolioData  String? // JSON blob: assets, goals, alerts, priceSheet, targetAllocation
  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Portfolio {
  id        String   @id @default(uuid())
  name      String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  assets    Asset[]
  goals     Goal[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Asset {
  id           String        @id @default(uuid())
  portfolioId  String
  ticker       String
  name         String
  category     AssetCategory
  currency     String        @default("INR")
  quantity     Decimal
  averagePrice Decimal
  portfolio    Portfolio     @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Transaction {
  id              String   @id @default(uuid())
  assetId         String
  transactionDate DateTime
  type            String   // BUY, SELL, DIVIDEND, SPLIT
  quantity        Decimal
  price           Decimal
  fee             Decimal  @default(0)
  notes           String?
  asset           Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
}

model Watchlist {
  id        String   @id @default(uuid())
  name      String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     String @default("[]")
  createdAt DateTime @default(now())
}

model Goal {
  id          String    @id @default(uuid())
  portfolioId String
  name        String
  targetValue Decimal
  deadline    DateTime?
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String   // INFO, WARNING, CRITICAL, SUCCESS
  read      Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model ImportJob {
  id         String    @id @default(uuid())
  userId     String
  fileName   String
  status     JobStatus @default(PENDING)
  errorLog   String?
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  action    String   // USER_LOGIN, TRANSACTION_ADD, etc.
  details   String?
  ipAddress String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model NewsArticle {
  id           String   @id @default(uuid())
  title        String
  url          String   @unique
  summary      String?
  source       String
  imageUrl     String?
  ticker       String?
  assetName    String?
  category     String?
  provider     String   // finnhub, newsdata, google
  impactScore  Int      @default(0)
  impactType   String   @default("neutral") // positive, negative, neutral
  publishedAt  DateTime
  createdAt    DateTime @default(now())

  bookmarks    NewsBookmark[]

  @@index([ticker])
  @@index([publishedAt])
  @@index([provider])
}

model NewsBookmark {
  id           String   @id @default(uuid())
  userId       String
  articleId    String
  article      NewsArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  readStatus   String   @default("unread") // unread, read, bookmarked
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, articleId])
  @@index([userId])
}
